<Window x:Class="CalendarApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Календарь" Height="450" Width="700"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Индикатор загрузки -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <ProgressBar x:Name="LoadingProgress" Width="120" Height="15" IsIndeterminate="True" Visibility="Collapsed"/>
            <TextBlock x:Name="LoadingText" Text="Загрузка..." Margin="10,0,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Список месяцев -->
        <ListBox x:Name="MonthsListBox" Grid.Row="1" Grid.Column="0" 
                 DisplayMemberPath="Name"
                 Margin="0,0,10,0"
                 SelectionChanged="MonthsListBox_SelectionChanged"/>

        <!-- Список событий -->
        <ListBox x:Name="EventsListBox" Grid.Row="1" Grid.Column="1"
                 Margin="0,0,0,0"
                 MouseDoubleClick="EventsListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="1" Margin="2" Padding="5">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                                      Content="{Binding Title}" FontWeight="Bold"
                                      Click="CheckBox_Click" />
                            <TextBlock Text="{Binding DateTime, StringFormat={}{0:g}}" FontSize="12"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>