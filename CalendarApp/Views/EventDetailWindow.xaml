<Window x:Class="CalendarApp.Views.EventDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали события" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock x:Name="TitleTextBlock" FontSize="20" FontWeight="Bold"/>
        <TextBlock x:Name="DateTimeTextBlock" Margin="0,10,0,0"/>
        <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap" Margin="0,10,0,0"/>
        <CheckBox x:Name="CompletedCheckBox" Content="Выполнено" Margin="0,20,0,0" Click="CompletedCheckBox_Click"/>
        <Button Content="Закрыть" Click="CloseButton_Click" Width="80" Height="30" Margin="0,20,0,0" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>